# ============================================================
# Copy this file to ".env" and adjust the values.
# The project runs FULLY LOCAL with Ollama by default —
# no API keys or internet required.
# ============================================================

# ---- AI model (local, via Ollama) ----
LLM_PROVIDER=ollama
OLLAMA_MODEL=qwen2.5-coder:7b
OLLAMA_HOST=http://localhost:11434

# Speed tuning for CPU-only laptops (optional, sensible defaults):
OLLAMA_KEEP_ALIVE=30m
OLLAMA_NUM_PREDICT=512

# ---- Database (local MySQL) ----
DB_TYPE=mysql
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=analytics_db

# ---- OPTIONAL cloud fallback (leave blank to stay fully local) ----
# Only used if you set LLM_PROVIDER=gemini above.
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.5-flash-lite
