# ---- LLM provider switch ----
# "ollama" = local model (free, unlimited, requires `ollama serve` running)
# "gemini" = cloud Gemini API
LLM_PROVIDER=ollama

# ---- Ollama (local; ignored if LLM_PROVIDER=gemini) ----
OLLAMA_MODEL=sqlcoder:7b
OLLAMA_HOST=http://localhost:11434

# ---- Gemini (cloud; ignored if LLM_PROVIDER=ollama) ----
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite

# ---- MySQL ----
MYSQL_HOST=localhost
MYSQL_USER=root
MYSQL_PASSWORD=your_mysql_password
MYSQL_DB=analytics_db
